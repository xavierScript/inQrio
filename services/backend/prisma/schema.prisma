generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exam {
  id        String     @id @default(uuid())
  examRefId String     @unique   // "chem-1983" (your stable reference)
  title     String               // "JAMB Chemistry 1983"
  examBoard String               // "JAMB" | "WAEC" | "SAT"
  subject   String               // "Chemistry" | "Mathematics"
  year      Int                  // 1983
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id            String   @id @default(uuid())
  questionRefId String   @unique   // "chem-1983-q1"
  text          String
  options       Json     // [{ key: "A", text: "Na2CO3" }, ...]
  correctOption String   // "C"
  explanation   String
  topic         String   // "Inorganic Chemistry"
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id])
}
